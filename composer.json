{
    "name": "kode/runtime",
    "description": "现代 PHP 常驻内存应用的统一运行时抽象层 | 支持 Swoole、Swow、PHP Fiber、多进程、多线程、Console 及传统 CLI 模式，基于 PHP 8.1+ 新特性构建",
    "keywords": ["runtime", "swoole", "swow", "fiber", "coroutine", "async", "php", "console"],
    "version": "2.1.0",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Kode Team",
            "email": "382601296@qq.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "kode/context": "^1.0"
    },
    "suggest": {
        "kode/console": "集成控制台输入输出功能和命令基类"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Runtime\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Runtime\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs --standard=PSR12 src/ tests/",
        "cs-fix": "phpcbf --standard=PSR12 src/ tests/"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.1-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
